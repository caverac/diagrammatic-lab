{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist-test",
    "rootDir": ".",
    "declaration": false,
    "declarationMap": false,
    "composite": false,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["jest", "node"],
    "paths": {
      "@core/*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "test/**/*"]
}
