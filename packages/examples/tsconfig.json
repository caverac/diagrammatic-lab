{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "types": ["node"],
    "paths": {
      "@examples/*": ["./src/*"],
      "@core/*": ["../core/src/*"],
      "@renderer/*": ["../renderer/src/*"]
    }
  },
  "references": [{ "path": "../core" }, { "path": "../renderer" }],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
