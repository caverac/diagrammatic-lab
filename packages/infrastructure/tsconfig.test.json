{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "isolatedModules": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "types": ["jest", "node"],
    "paths": {
      "@infra/*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "test/**/*"]
}
