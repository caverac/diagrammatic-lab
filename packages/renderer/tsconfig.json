{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "paths": {
      "@renderer/*": ["./src/*"],
      "@core/*": ["../core/src/*"]
    }
  },
  "references": [{ "path": "../core" }],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "dist-test", "test"]
}
