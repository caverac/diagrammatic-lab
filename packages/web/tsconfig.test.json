{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["jest", "node"],
    "paths": {
      "@/*": ["./src/*"],
      "@core/*": ["../core/src/*"],
      "@renderer/*": ["../renderer/src/*"],
      "@diagrammatic-lab/core": ["../core/src/index.ts"],
      "@diagrammatic-lab/renderer": ["../renderer/src/index.ts"]
    }
  },
  "include": ["test/**/*"]
}
